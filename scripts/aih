CORE_DIRS = ["templates", "playbooks", "checklists", "swarm", "protocols", "rubrics", "packs", "runs"]
RELEASE_GATES = [
    "clear target user and use case",
    "repeatable input format",
    "explicit output contract",
    "validation method",
    "failure handling",
    "safety/privacy boundary",
    "versioned release notes",
