ROOT = Path(os.environ.get("AI_HARNESS_HOME", DEFAULT_ROOT)).expanduser().resolve()
SEARCH_DIRS = ["templates", "playbooks", "checklists", "swarm", "protocols", "rubrics", "packs"]
CORE_FILES = [
