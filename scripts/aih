#!/usr/bin/env python3
"""Simple overlay CLI for the Dmitriy AI Harness.

This file is a thin backward-compatible wrapper. All logic lives in the
aih/ package. Running ``scripts/aih`` directly or via ``python3 -m aih``
both work.
"""

from __future__ import annotations

import sys
from pathlib import Path

# Ensure the repo root is on sys.path so ``import aih`` works when
# running the script directly (before pip-install).
_repo = Path(__file__).resolve().parents[1]
if str(_repo) not in sys.path:
    sys.path.insert(0, str(_repo))

from aih.cli import main  # noqa: E402

if __name__ == "__main__":
    raise SystemExit(main())
else:
    # When imported as a module (e.g. by tests calling subprocess on this
    # file), just expose main.
    raise SystemExit(main())
