    "handoff or support note",
]
SENSITIVE_REQUEST_PATTERNS = (
    re.compile(r"(?i)\b(sk-[A-Za-z0-9_-]{12,})"),
    re.compile(r"(?i)\b(api[_-]?key|token|password|secret)\s*[:=]\s*\S+"),
)

